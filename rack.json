{
  "name": "Benchmark",
  "version": "1.0",
  "start": "zsh start.sh",
  "startup_delay": 3,
  "port": 8766,
  "heartbeat_interval": 5,
  "controls": [
    {
      "id": "model_select",
      "type": "dropdown",
      "label": "Model"
    },
    {
      "id": "parallel",
      "type": "dropdown",
      "label": "Parallel"
    },
    {
      "id": "run",
      "type": "button",
      "label": "Run",
      "style": "primary"
    },
    {
      "id": "status_label",
      "type": "label",
      "value": "Idle",
      "style": "default"
    }
  ]
}
